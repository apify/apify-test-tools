{
    "extends": "@apify/tsconfig",
    "compilerOptions": {
        "declaration": true,
        "module": "ES2022",
        "target": "ES2022",
        "outDir": "dist",
        "noUnusedLocals": false,
        "strict": true,
        "esModuleInterop": true,
        "lib": ["DOM", "es2021"],
        "skipLibCheck": true,
    },
    "include": [
        "./index.ts",
        "./bin/**/*",
        "./lib/**/*",
        "./test/**/*",
    ]
}
